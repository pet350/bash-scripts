function CHECK_COLOR_SUPPORT()
{
  declare -i FUNCTION_RETURN=$FAILURE
  if [ ${#COLOR_SUPPORT} -ne 0 ]; then
    if [ $COLOR_SUPPORT -eq $TRUE ]; then FUNCTION_RETURN=$SUCCESS; fi
  fi
  return $FUNCTION_RETURN
};

