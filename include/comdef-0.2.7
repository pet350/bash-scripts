# Print Date and Time
function SHOW_DATE_TIME()
{
  CHECK_COLOR_SUPPORT
  if [ $? -eq $SUCCESS ]; then
    printf "%b[ %10s @ %5s ] %b" $COLOR_LT_GREEN $(date +%F) $(date +%R) $COLOR_NORMAL
  else
    printf "[ %10s @ %5s ] " $(date +%F) $(date +%R)
  fi
  return $SUCCESS
};

function CHECK_CMD_LINE()
{
  if [ $CMD_LINE_COUNT -eq 0 ]; then
    echo -e $COLOR_LT_GREEN"$RUN_CMD"$COLOR_LT_BLUE"\tVersion: $VERSION"$COLOR_LT_GREEN"\nUsage:"$COLOR_LT_BLUE" $RUN_CMD [options] --help\n"$COLOR_NORMAL
    exit $SUCCESS
  fi
  return $SUCCESS
};

function REQUIRE_ROOT_USER()
{
  if [ $(id -u) -gt 0 ]; then
    echo -e $COLOR_LT_GREEN"$RUN_CMD"$COLOR_LT_BLUE"\tVersion: $VERSION\n"$COLOR_YELLOW"Must be ran as root"$COLOR_NORMAL
    exit $FAILURE
  fi
  return $SUCCESS
};

function REQUIRE_NON_ROOT_USER()
{
  if [ $(id -u) -eq 0 ]; then
    echo -e $COLOR_LT_GREEN"$RUN_CMD"$COLOR_LT_BLUE"\tVersion: $VERSION\n"$COLOR_YELLOW"Cannot be ran as root"$COLOR_NORMAL
    exit $FAILURE
  fi
  return $SUCCESS
};

function CHECK_ROOT_USER()
{
  CHECK_COLOR_SUPPORT
  if [ $? -eq $SUCCESS ]; then
    if [ $(id -u) -eq 0 ]; then
      if [ $BOL_ENABLE_ROOT -eq $FALSE ]; then
        SHOW_DATE_TIME; echo -e $COLOR_LT_GREEN"$RUN_CMD"$COLOR_LT_BLUE"\tVersion: $VERSION\n"$COLOR_YELLOW"[WARNING] "$COLOR_CYAN"Shouldn't be ran as root! Use "$COLOR_LT_BLUE"--enable-root"$COLOR_CYAN" to bypass this safty check."$COLOR_NORMAL"\n\n"
        exit $SUCCESS
      else
        SHOW_DATE_TIME; echo -e $COLOR_LT_GREEN"$RUN_CMD"$COLOR_LT_BLUE"\tVersion: $VERSION\n"$COLOR_YELLOW"[WARNING] "$COLOR_CYAN"Enabled root user"$COLOR_NOTMAL"\n\n"
      fi
    fi
  else
    if [ $(id -u) -eq 0 ]; then
      if [ $BOL_ENABLE_ROOT -eq $FALSE ]; then
        echo -e "$RUN_CMD\tVersion: $VERSION\n[WARNING] Shouldn't be ran as root! Use --enable-root to bypass this safty check.\n\n"
        exit $SUCCESS
      else
        echo -e "$RUN_CMD\tVersion: $VERSION\n[WARNING] Enabled root user\n\n"
      fi
    fi
  fi
  return $SUCCESS
};

function LOG_RESULTS()
{
  if	[ ${#COLOR_SUPPORT} -eq 0 ]; then declare -i COLOR_SUPPORT=$FALSE; fi
  if	[ ${#COMMAND} -gt 0 ] && [ ${#EXT_OPT} -eq 0 ]; then export DATA="$COMMAND"
  elif	[ ${#EXT_OPT} -gt 0 ] && [ ${#COMMAND} -eq 0 ]; then export DATA="$EXT_OPT"
  elif	[ ${#COMMAND} -gt 0 ] && [ ${#EXT_OPT} -gt 0 ]; then export DATA="$COMMAND $EXT_OPT"
  else export DATA='*'; fi
  if [ $COLOR_SUPPORT -eq $TRUE ]; then
    if [ $RETVAL -eq $SUCCESS ]; then
      printf "%b%s%b " $COLOR_YELLOW "$DATA" $COLOR_GREEN; log_success_msg "Success!"; printf "%b" $COLOR_NORMAL
    else
      printf "%b%s%b " $COLOR_YELLOW "$DATA" $COLOR_RED; log_failure_msg "Failure!"; printf "%b" $COLOR_NORMAL
    fi
  else
    if [ $RETVAL -eq $SUCCESS ]; then
      printf "%s " "$DATA"; log_success_msg "Success!"
    else
      printf "%s " "$DATA"; log_failure_msg "Failure!"
    fi
  fi
  unset DATA
  return $RETVAL
};

if [ ${#HELP_ARRAY[@]} -eq 0 ]; then
  declare -ag HELP_ARRAY=();
fi

function DO_HELP()
{
  declare -i INDEX=-1
  declare -i TEMP_LEN=0
  declare -i SWITCH_LEN=0
  declare -i COMMAND_LEN=0

  echo -e $COLOR_LT_GREEN"$RUN_CMD"$COLOR_YELLOW"\tVersion: $VERSION"$COLOR_LT_BLUE"\nUsage: $RUN_CMD [options]\n"$COLOR_NORMAL

  # First nested loop to get longest string length of both "switch" and "command"
  while IFS= read LINE; do
    INDEX=-1
    unset COMMAND
    unset SWITCH
    for DATA in $LINE; do
      ((INDEX++))
      if [ $INDEX -eq 0 ]; then
        SWITCH="$DATA"
        TEMP_LEN=${#SWITCH}
        if [ $TEMP_LEN -gt $SWITCH_LEN ]; then SWITCH_LEN=$((TEMP_LEN)); fi
      else
	COMMAND="$COMMAND $DATA"
	TEMP_LEN=${#COMMAND}
	if [ $TEMP_LEN -gt $COMMAND_LEN ]; then COMMAND_LEN=$((TEMP_LEN)); fi
      fi
    done
    unset DATA
  done < <(echo -e ${HELP_ARRAY[@]})

  # Second nested loop to display the help messages
  while IFS= read LINE; do
    INDEX=-1
    unset COMMAND
    unset SWITCH
    for DATA in $LINE; do
      ((INDEX++))
      if [ $INDEX -eq 0 ]; then
        SWITCH="$DATA"
      else
        COMMAND="$COMMAND $DATA"
      fi
    done
    unset DATA
    printf "%b%-$((SWITCH_LEN+1))s%b: %b%-$((COMMAND_LEN+1))s%b\n" $COLOR_LT_GREEN "$SWITCH" $COLOR_NORMAL $COLOR_YELLOW "$COMMAND" $COLOR_NORMAL
  done < <(echo -e ${HELP_ARRAY[@]})
  echo -e "\n"
  exit $SUCCESS
};

function STANDARD_CMD_LINE_OPTIONS()
{
  declare -ag OPTION_ARRAY=();
  declare -i CMDLINE_COUNT=0
  for i in ${CMDLINE[@]}; do
    ((CMDLINE_COUNT++))
    case $i in
      '--check')
	export BOL_CHECK=$TRUE
	;;
      '--no-wait')
	export BOL_WAIT=$FALSE
	;;
      '-h' | '--help')
	export BOL_HELP=$TRUE
	export BOL_START=$FALSE
	export BOL_STOP=$FALSE
	;;
      '-v' | '--verbose')
	export BOL_VERBOSE=$TRUE
	export VERBOSE="--verbose"
	;;
      '-q' | '--quiet')
        export BOL_VERBOSE=$FALSE
        export VERBOSE=""
        ;;
      '--debug')
	export DEV_NULL="/dev/stdout"
	export BOL_DEBUG=$TRUE
	;;
      'start')
        export BOL_START=$TRUE
	export BOL_STOP=$FALSE
        ;;
      'stop')
	export BOL_START=$FALSE
	export BOL_STOP=$TRUE
	;;
      'restart')
	export BOL_STOP=$TRUE
	export BOL_START=$TRUE
	;;
      '--version')
	echo -e "$RUN_CMD\tVersion: $VERSION\nBy:\t\tPeter Talbott"
	exit $SUCCESS
	;;
      '--bw')
	export BOL_COLOR=$FALSE
	;;
      '--color')
	export BOL_COLOR=$TRUE
	;;
      *)
	OPTION_ARRAY_COUNT=${#OPTION_ARRAY[@]}
        OPTION_ARRAY[$((OPTION_ARRAY_COUNT))]="$i"
	;;
    esac
  done
  return $CMDLINE_COUNT
};

# Function that gets current system load *100 (No floating point)
function GET_SYS_LOAD()
{
  declare -i INDEX=-1
  declare -i COUNT=$($UPTIME_BIN | $WC_BIN -w)
  for DATA in $($UPTIME_BIN); do
    ((INDEX++))
    if [ $INDEX -eq $((COUNT-3)) ]; then LOAD="$DATA"; fi
  done
  INDEX=${#LOAD}
  OUTPUT="${LOAD:0:$((INDEX-4))}${LOAD:$((INDEX-3)):$((INDEX-3))}"
  if [ "${OUTPUT:0:1}" == "0" ]; then OUTPUT=${OUTPUT:1:2}; fi
  INDEX=${#OUTPUT}
  if [ "${OUTPUT:$((INDEX-1)):$((INDEX))}" == "," ]; then OUTPUT=${OUTPUT:0:$((INDEX-1))}; fi 
  printf "%s" $SHOW_OUT
  return $INDEX
};
