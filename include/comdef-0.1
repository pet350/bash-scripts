export TEMP="mencoder";		export MENCODER_BIN=$(GET_BIN)
export TEMP="sleep";		export SLEEP_BIN=$(GET_BIN)
export TEMP="ffmpeg";		export FFMPEG_BIN=$(GET_BIN)
export TEMP="mount";		export MOUNT_BIN=$(GET_BIN)
export TEMP="umount";		export UMOUNT_BIN=$(GET_BIN)
export TEMP="true";		export TRUE_BIN=$(GET_BIN)
export TEMP="false";		export FALSE_BIN=$(GET_BIN)
export TEMP="systemctl";	export SYSCTL_BIN=$(GET_BIN)
export TEMP="update-rc.d";	export UPDATE_RC_BIN=$(GET_BIN)
export TEMP="blkid";		export BLKID_BIN=$(GET_BIN)
export TEMP="fsck";		export FSCK_BIN=$(GET_BIN)
export TEMP="fsck.ext4";        export FSCK_EXT4_BIN=$(GET_BIN)
export TEMP="xfs_repair";	export FSCK_XFS_BIN=$(GET_BIN)
