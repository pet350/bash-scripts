# Common Definitions Script Include File
# To simplify script writting, I Use this file for MOST functions
# that I use on a regualar basis
# Peter Talbott
# Version 0.1

# Define Command Enetered in at the Terminal
export RUN_CMD="$(basename $0)"
export COMDEF_VERSION="0.1"
declare -ig CMD_LINE_COUNT=${#CMDLINE[@]}

# Define TRUE/FALSE Variables
if [ ${#TRUE}		-eq 0 ];	then 	declare -ig TRUE=1;		fi
if [ ${#FALSE}		-eq 0 ];	then    declare -ig FALSE=0;       	fi

# Define SUCCESS/FAILURE Variables
declare -ig SUCCESS=0
declare -ig FAIL=1

# Define UP and DOWN
declare -ig UP=1
declare -ig DOWN=0

# Define Global Boolean Variables
declare -ig BOL_VERBOSE=$FALSE
declare -ig BOL_QUIET=$FALSE
declare -ig BOL_HELP=$FALSE
declare -ig BOL_TEMP=$FALSE
declare -ig BOL_DEBUG=$FALSE
declare -ig BOL_WAIT=$TRUE
declare -ig BOL_LOG_RESULTS=$TRUE
declare -ig BOL_COLOR=$TRUE

# Define Global SYSCTL Boolean Variables
declare -ig BOL_START=$FALSE
declare -ig BOL_STOP=$FALSE
declare -ig BOL_RESTART=$FALSE
declare -ig BOL_RELOAD=$FALSE
declare -ig BOL_STATUS=$FALSE
declare -ig BOL_MASK=$FALSE
declare -ig BOL_UNMASK=$FALSE
declare -ig BOL_ENABLE=$FALSE
declare -ig BOL_DISABLE=$FALSE

# Define Directoy Prefix String Variables
export BIN_PREFIX="/bin"
export USR_PREFIX="/usr"
export CFG_PREFIX="/etc"
export LIB_PREFIX="/lib"
export VAR_PREFIX="/var"
export SBIN_PREFIX="/sbin"
export LOCAL_PREFIX="/local"

# Function that gets the full path of a binary
function GET_BIN()
{
  export FIND_BIN="$BIN_PREFIX/find"
  declare -i COUNT=-1
  for DATA in $($FIND_BIN -L $BIN_PREFIX $SBIN_PREFIX $USR_PREFIX$BIN_PREFIX $USR_PREFIX$SBIN_PREFIX -executable -iname "$TEMP" 2>/dev/null); do
    ((COUNT++))
    if [ $COUNT -eq 0 ]; then echo $DATA; fi
  done
  unset DATA
  unset COUNT
  return $?
};

# Define Commonly Used Binary Variables
export TEMP="ip";		export IP_BIN=$(GET_BIN)
export TEMP="lsmod";		export LSMOD_BIN=$(GET_BIN)
export TEMP="insmod";		export INSMOD_BIN=$(GET_BIN)
